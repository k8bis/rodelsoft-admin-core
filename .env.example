# =========================
# DB PRINCIPAL
# =========================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=proyecto_db

# =========================
# CORE AUTH / SESSION
# =========================
SECRET_KEY=CHANGE_ME_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# =========================
# CONTROL PLANE INTERNO
# =========================
CONTROL_PLANE_BASE_URL=http://app-hija-1:8000

# =========================
# COOKIES
# =========================
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# =========================
# AUTHZ
# =========================
AUTHZ_ADMIN_KEY=CHANGE_ME_AUTHZ_KEY
AUTHZ_ENABLE_DOCS=false

# =========================
# REFERENCIA PÚBLICA
# =========================
PUBLIC_BASE_URL=http://your-public-host:8088
